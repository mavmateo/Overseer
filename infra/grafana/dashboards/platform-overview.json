      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawSql": "WITH latest_telemetry AS ( SELECT DISTINCT ON (asset_id) asset_id, site_id, ts_source, quality FROM measurements WHERE ts_source >= NOW() - INTERVAL '24 hours' ORDER BY asset_id, ts_source DESC ), open_alarms AS ( SELECT asset_id, COUNT(*) FILTER (WHERE state = 'open') AS open_alarm_count FROM alarms WHERE raised_at >= NOW() - INTERVAL '24 hours' GROUP BY asset_id ) SELECT lt.ts_source AS time, lt.asset_id, CASE WHEN COALESCE(oa.open_alarm_count, 0) > 0 THEN 'attention' WHEN lt.ts_source < NOW() - INTERVAL '5 minutes' THEN 'stale' ELSE 'healthy' END AS health, COALESCE(oa.open_alarm_count, 0) AS open_alarm_count, lt.quality FROM latest_telemetry lt LEFT JOIN open_alarms oa USING (asset_id) ORDER BY lt.asset_id;",
          "rawQuery": true,
          "refId": "A"
        }
      ],
      "title": "Recent Asset Health",
      "type": "table"
