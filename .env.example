# Core platform defaults
PLATFORM_NAME=og-iot-platform
DEPLOYMENT_MODE=dev
DATABASE_URL=postgresql://postgres:postgres@timescaledb:5432/og_iot
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=platform
MQTT_PASSWORD=platform-secret
MQTT_SITE_TOPIC_PREFIX=site
OPENBAO_ADDR=http://openbao:8200
GRAFANA_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
MODEL_ARTIFACT_ROOT=/data/models
STORE_BUFFER_PATH=/data/site-forwarder/buffer.db
SITE_ID=site-alpha
AREA_ID=processing
ASSET_ID=crusher-01
GRAPHQL_PORT=8080
API_PORT=8000
LIVE_FEED_PORT=8090

