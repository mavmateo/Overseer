{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/model-deployment.schema.json",
  "title": "ModelDeployment",
  "type": "object",
  "required": [
    "modelId",
    "version",
    "checksum",
    "inputSchema",
    "approvalState",
    "targetScope"
  ],
  "properties": {
    "modelId": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "checksum": { "type": "string", "minLength": 1 },
    "inputSchema": { "type": "string", "minLength": 1 },
    "approvalState": {
      "type": "string",
      "enum": ["draft", "approved", "rejected"]
    },
    "targetScope": { "type": "string", "minLength": 1 },
    "rollbackVersion": { "type": "string" }
  },
  "additionalProperties": false
}
